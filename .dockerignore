# Cargo build artifacts. The double-star prefixes match nested target
# dirs (e.g. ministr-app/src-tauri/target/) which BuildKit prunes at
# the walk stage, so the 46 GB target tree never enters the tarball.
# Without these explicit nested forms, `az acr build` and some other
# tar packers walk the entire tree before applying patterns and
# spend minutes on a no-op.
target/
**/target/
**/.cargo/registry/
**/.cargo/git/
.git/
docs/
.fastembed_cache/
**/.fastembed_cache/
.DS_Store

# Local Pulumi state cache (not needed in container).
deploy/azure/node_modules/

# Documentation (not needed in container)
*.md
!deploy/README.md

# Frontend build artifacts
node_modules/
**/node_modules/
ministr-app/dist/
**/dist/

# IDE and editor configs
.claude/
.continue/
.cursor/
.vscode/
.windsurf/

# Workflow and planning state
.magistr/
.magistr-roadmap.yml
.magistr-roadmap.yml.lock
.mcp.json
launch/

# Signing credentials
.env.signing

# GitHub metadata
.github/

# Evaluation and benchmarks (not needed in container)
eval/

# Tauri app — the Docker image only builds ministr-cli, but cargo-chef
# still needs to read every workspace member's Cargo.toml to generate
# the dependency recipe. Keep the crate's manifest + source in context
# and let `cargo build -p ministr-cli` simply not compile ministr-app.
# The large frontend-only artifacts (dist/, node_modules/) are still
# excluded above.
ministr-app/src/
ministr-app/dist/
ministr-app/node_modules/
ministr-app/pnpm-lock.yaml
ministr-app/package.json
ministr-app/tsconfig*.json
ministr-app/vite.config.ts
ministr-app/index.html
