# Local cloud-mode env template. Copy to `.env.dev` and fill in the
# Stripe + GitHub bits per DEMO.md. Then:
#
#   source .env.dev
#   cargo run -p ministr-cli -- serve --transport http --oauth
#
# The Postgres URL points at the `docker compose -f
# docker-compose.dev.yml up` container; the rest live in the vendor
# dashboards.

# ── Required: database ─────────────────────────────────────────────────
# Points at the host port the dev docker-compose maps Postgres to.
# `sslmode=disable` is the dev path; production uses
# `sslmode=require` against Azure Postgres Flex (TLS is wired
# unconditionally by `ministr-cloud::connect`).
export MINISTR_PG_URL="postgres://ministr:ministr@localhost:55432/ministr_dev?sslmode=disable"

# ── Required: public base URL ──────────────────────────────────────────
# What the browser-side callback URLs (GitHub OAuth, Stripe success_url)
# resolve to. Must match the URL GitHub OAuth App + Stripe products are
# configured with. For pure local dev, http://localhost:8080.
export MINISTR_CLOUD_BASE_URL="http://localhost:8080"

# ── Optional: allowed hosts ────────────────────────────────────────────
# Comma-separated. The Streamable-HTTP transport guards the Host header
# against this list. Leave unset for loopback-only.
# export MINISTR_ALLOWED_HOSTS="localhost,127.0.0.1"

# ── Required for F1.3 GitHub sign-in ───────────────────────────────────
# Register a GitHub OAuth App at https://github.com/settings/applications/new
# Callback URL: $MINISTR_CLOUD_BASE_URL/auth/github/callback
export MINISTR_GITHUB_CLIENT_ID=""
export MINISTR_GITHUB_CLIENT_SECRET=""

# ── Optional for F1.5/F2.4 Stripe billing ──────────────────────────────
# Stripe Dashboard → Developers → API keys.
# Use `sk_test_…` for the dev flow.
export MINISTR_STRIPE_SECRET_KEY=""
# Stripe Dashboard → Developers → Webhooks → endpoint signing secret.
# Locally: `stripe listen --forward-to localhost:8080/webhooks/stripe`
# prints a `whsec_…` to paste here.
export MINISTR_STRIPE_WEBHOOK_SECRET=""
# Stripe Dashboard → Products → "ministr Pro" + "ministr Team" → recurring
# price IDs (start with `price_`).
export MINISTR_STRIPE_PRICE_PRO=""
export MINISTR_STRIPE_PRICE_TEAM=""

# ── Optional for F2.1 GitHub App private-repo cloning ──────────────────
# https://github.com/settings/apps/new — scopes contents:read +
# metadata:read. The private key download is a multi-line PEM; paste
# the whole thing here (newlines preserved):
export MINISTR_GITHUB_APP_ID=""
export MINISTR_GITHUB_APP_PRIVATE_KEY=""

# ── Optional: GitHub push webhook signing secret ───────────────────────
# Only needed if you've wired the GitHub App's "push" webhook to
# /webhook/github for auto-reindex (F2.1 sub-bullet 8 carry-over).
export MINISTR_GITHUB_WEBHOOK_SECRET=""

# ── Optional: persistent OAuth state ───────────────────────────────────
# Default is in-memory (resets on restart). Set to a directory and the
# OAuth state + admin job queue live in an SQLite file there.
# export MINISTR_CLOUD_DATA_DIR="$HOME/.ministr/cloud-dev"
