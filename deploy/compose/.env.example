# F5.4-d — copy to `.env` and fill in. `docker compose up` reads
# this file automatically. Required vars are flagged with `# req`.

# ── F5.4-a license gate (required) ─────────────────────────────────

# req — RS256 JWT issued by the ministr license portal (F5.4-e).
# Paste the entire token on one line (no line breaks).
MINISTR_LICENSE_KEY=eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9.PASTE_FROM_PORTAL...

# req — PEM-encoded SPKI public key from ministr (out-of-band).
# Multi-line PEM is fine in .env when the value is quoted with `"…"`
# and newlines are LITERAL `\n` characters; OR (easier) collapse the
# PEM to a single line by replacing internal newlines with spaces
# and keep the BEGIN / END markers.
MINISTR_LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nPASTE_FROM_MINISTR...\n-----END PUBLIC KEY-----"

# ── Bundled Postgres (required when using the bundled `postgres` service) ──

# req — password for the bundled Postgres instance. Generate with
# `openssl rand -base64 32 | tr -d '+/='` or similar.
POSTGRES_PASSWORD=replace-me-with-a-real-password

# ── Optional overrides ────────────────────────────────────────────

# Host port to publish the cloud serve on. Default 8080.
# PORT=8080

# Container image. Default `ghcr.io/ministr-ai/cloud:0.6.0`. Override
# to your own mirror when running behind a firewall or pinning to a
# specific build.
# MINISTR_IMAGE=ghcr.io/ministr-ai/cloud:0.6.0

# ── Production (external DB) ──────────────────────────────────────
#
# To run against your own external Postgres, set this and remove the
# `postgres` service from the compose file (or start only the
# `cloud` service via `docker compose up -d cloud`).
# MINISTR_PG_URL=postgres://user:pass@your-db.example.com:5432/ministr?sslmode=require

# ── F5.3-c-ii-archive cold archive (optional) ─────────────────────
#
# Path inside the container where archived audit partitions land.
# Defaults to a path backed by the `ministr-audit-archive` named
# volume. Set to empty to disable.
# MINISTR_AUDIT_ARCHIVE_DIR=/var/lib/ministr/audit-archive
