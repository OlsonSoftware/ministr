# Caddy reverse proxy for iris MCP server
# Auto-TLS via ACME + SSE passthrough
#
# Usage:
#   1. Replace iris.example.com with your domain
#   2. caddy run --config Caddyfile

iris.example.com {
	reverse_proxy localhost:8080 {
		# Disable response buffering for SSE streams
		flush_interval -1

		# MCP sessions can be long-lived
		transport http {
			read_timeout 300s
			write_timeout 300s
			keepalive 30s
		}
	}
}
