[56.325422, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[2C\u001b[5A\u001b[34mdef\u001b[33m \u001b[39mgreet(name:\u001b[1C\u001b[36mstr\u001b[33m, tone: Tone = Tone.FRIENDLY\u001b[39m)\u001b[1C->\u001b[1C\u001b[36mstr\u001b[33m:\r\u001b[1B\u001b[39m      \u001b[31m\"\"\"Return a greeting for `name` in the requested tone.\"\"\"\u001b[39m                                 \r\u001b[1B   \u001b[3Cmatch\u001b[1Ctone:\r\u001b[1B          case Tone.FORMAL:                                                                     \r\u001b[2C\u001b[1B            \u001b[34mreturn\u001b[39m \u001b[31mf\"Good day, \u001b[39m{name}.\"                   \r\r\n\u001b[10Ccase\u001b[1CTone.FRIENDLY:\r\r\n\r\r\n\u001b[38;2;136;136;136mв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\u001b[39m\r\r\n\u001b[38;2;153;153;153mвқҜВ \u001b[39m\u001b[7m \u001b[27m\r\r\n\u001b[38;2;136;136;136mв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ"]
