<?xml version="1.0" encoding="utf-8" standalone="no"?>
<installer-gui-script minSpecVersion="2">
    <title>iris</title>
    <organization>com.iris</organization>
    <domains enable_localSystem="true" enable_currentUserHome="false" />
    <options customize="allow" require-scripts="false" hostArchitectures="arm64,x86_64" />

    <!-- System requirements -->
    <os-version min="13.0" />

    <!-- Custom installer pages -->
    <welcome    file="welcome.html"    mime-type="text/html" />
    <readme     file="readme.html"     mime-type="text/html" />
    <license    file="license.html"    mime-type="text/html" />
    <conclusion file="conclusion.html" mime-type="text/html" />

    <!-- Installer background — light and dark mode -->
    <background          file="background.png" mime-type="image/png" scaling="tofit" alignment="bottomleft" />
    <background-darkAqua file="background-dark.png" mime-type="image/png" scaling="tofit" alignment="bottomleft" />

    <!-- Component choices -->
    <choices-outline>
        <line choice="choice-app" />
        <line choice="choice-cli" />
    </choices-outline>

    <!-- iris.app — always installed -->
    <choice id="choice-app"
            visible="true"
            enabled="true"
            selected="true"
            title="iris Desktop"
            description="The iris desktop app — system tray daemon with GUI dashboard for managing context indexes.">
        <pkg-ref id="com.iris.desktop.app" />
    </choice>

    <!-- iris CLI — optional but selected by default -->
    <choice id="choice-cli"
            visible="true"
            enabled="true"
            selected="true"
            title="iris CLI"
            description="The iris command-line tool. Installs to /usr/local/bin/iris and adds it to your PATH.">
        <pkg-ref id="com.iris.desktop.cli" />
    </choice>

    <!-- Package references (paths relative to the package-path argument) -->
    <pkg-ref id="com.iris.desktop.app"
             version="__VERSION__"
             onConclusion="none">iris-app.pkg</pkg-ref>

    <pkg-ref id="com.iris.desktop.cli"
             version="__VERSION__"
             onConclusion="none">iris-cli.pkg</pkg-ref>
</installer-gui-script>
