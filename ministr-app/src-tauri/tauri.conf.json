{
  "$schema": "https://raw.githubusercontent.com/nickelpack/nk/main/schemas/tauri/2.0/config.schema.json",
  "productName": "ministr",
  "identifier": "ai.ministr.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "ministr",
        "width": 1280,
        "height": 800,
        "minWidth": 920,
        "minHeight": 640,
        "resizable": true,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/ministr-cli"
    ],
    "resources": [
      "resources/*"
    ],
    "macOS": {
      "signingIdentity": null,
      "entitlements": "./Entitlements.plist",
      "minimumSystemVersion": "13.0",
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0"
        ],
        "section": "utils",
        "postInstallScript": "scripts/linux-postinstall.sh"
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3"
        ],
        "release": "1",
        "postInstallScript": "scripts/linux-postinstall.sh"
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "installerHooks": "installer-hooks.nsh"
      }
    },
    "category": "DeveloperTool",
    "shortDescription": "Code intelligence MCP server for AI coding agents",
    "longDescription": "ministr is a code intelligence MCP server. It gives AI coding agents AST-level understanding of a codebase — semantic search, symbol navigation, reference graphs, and cross-language bridge detection across ~29 languages, all local. As a bonus, it remembers what it already sent and ships only what changed on the next turn."
  }
}
