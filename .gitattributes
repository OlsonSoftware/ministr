# Normalize line endings to LF in the repo; check out as-is on all platforms.
* text=auto eol=lf

# Windows batch/PowerShell scripts that must have CRLF on checkout.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Vendored third-party source — exclude from language stats and collapse
# the huge generated tree-sitter parser.c in diffs/reviews.
third_party/** linguist-vendored
third_party/tree-sitter-unreal-cpp/src/parser.c -diff -merge

# Binary files — no line ending conversion.
*.exe binary
*.dll binary
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.wasm binary
